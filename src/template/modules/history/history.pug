      .history__section-header.section-header
        h2.title  
          | Мы в социальных сетях
        p.section-header__text 
          | Подписывайтесь на наши аккаунты, следите за выгодными предложениями
          br 
          | и задавайте вопросы. Мы всегда рады новым знакомствам!
      .history__social-list.social-list
        a.social-list__item(href="#")
          .social-list__icon
            +svg('fc', 'social-list__svg')
          .social-list__content
            p.social-list__name Facebook
            .social-list__success-item.success-item
              +obj('success-blue', 'success-item__svg')
              p.success-item__text 5 456 
        a.social-list__item.social-list__item--red(href="#")
          .social-list__icon
            +svg('yo', 'social-list__svg')
          .social-list__content
            p.social-list__name Youtube
            .social-list__success-item.success-item
              +obj('success-blue', 'success-item__svg')
              p.success-item__text 24 568 
        a.social-list__item.social-list__item--pink(href="#")
          .social-list__icon
            +svg('inst', 'social-list__svg')
          .social-list__content
            p.social-list__name Instagram
            .social-list__success-item.success-item
              +obj('success-blue', 'success-item__svg')
              p.success-item__text 80 145
        a.social-list__item(href="#")
          .social-list__icon
            +svg('vk', 'social-list__svg')
          .social-list__content
            p.social-list__name Вконтакте
            .social-list__success-item.success-item
              +obj('success-blue', 'success-item__svg')
              p.success-item__text 14 456 
